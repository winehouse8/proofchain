{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Baseline TC File",
  "description": "Test Case specification file generated by /test-gen-design",
  "type": "object",
  "required": ["spec_id", "generated_at", "baseline_tcs"],
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^SPEC-[A-Z]+-[A-Z]+$",
      "description": "Source SPEC identifier, e.g. SPEC-{code}-GP"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "baseline_tcs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tc" }
    }
  },
  "$defs": {
    "tc": {
      "type": "object",
      "required": ["tc_id", "origin", "req_id", "type", "level", "title", "given", "when", "then"],
      "properties": {
        "tc_id": {
          "type": "string",
          "pattern": "^TC-[A-Z]+-\\d{3}[a-z]$",
          "description": "Unique TC ID, e.g. TC-GP-001a"
        },
        "origin": {
          "type": "string",
          "const": "baseline",
          "description": "Must be 'baseline' for this skill. Supplementary TCs are added by /test-gen-code."
        },
        "status": {
          "type": "string",
          "enum": ["active", "obsolete"],
          "default": "active",
          "description": "active = normal execution. obsolete = skipped during test runs but preserved for audit trail."
        },
        "obsoleted_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "default": null,
          "description": "Timestamp when this TC was marked obsolete. null if active."
        },
        "obsoleted_by": {
          "type": ["string", "null"],
          "default": null,
          "description": "TC ID of the supplementary TC that supersedes this one. null if active."
        },
        "obsolete_reason": {
          "type": ["string", "null"],
          "default": null,
          "description": "Why this TC is no longer valid (e.g. 'REQ-GP-003 changed: zoom reset → fit-to-content'). null if active."
        },
        "req_id": {
          "type": "string",
          "pattern": "^REQ-[A-Z]+-\\d{3}$",
          "description": "Linked requirement ID, e.g. REQ-GP-001"
        },
        "type": {
          "type": "string",
          "enum": ["positive", "negative", "boundary", "error"]
        },
        "level": {
          "type": "string",
          "enum": ["unit", "component", "api", "e2e", "visual"]
        },
        "title": {
          "type": "string",
          "minLength": 5,
          "description": "Short description of what the TC verifies"
        },
        "given": {
          "type": "string",
          "minLength": 5,
          "description": "Precondition"
        },
        "when": {
          "type": "string",
          "minLength": 5,
          "description": "Action or trigger"
        },
        "then": {
          "type": "string",
          "minLength": 5,
          "description": "Expected outcome"
        }
      },
      "additionalProperties": false
    }
  }
}
